<Window x:Class="KickVOD.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KickDownloader Pro" Height="700" Width="640" WindowStartupLocation="CenterScreen" 
        Background="Transparent" AllowsTransparency="True" WindowStyle="None" ResizeMode="CanMinimize" Foreground="White" FontFamily="Segoe UI"
        Icon="pack://application:,,,/icon.ico">

    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#25272B"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#3D424B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#53FC18"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#65FF30"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#333333"/>
                    <Setter Property="Foreground" Value="#888888"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Foreground" Value="#53FC18"/>
            <Setter Property="Background" Value="#25272B"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}" HorizontalAlignment="Left" CornerRadius="4"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#25272B"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#3D424B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="SnapsToDevicePixels" Value="true"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#25272B"/>
                        <Setter Property="Foreground" Value="#E0E0E0"/>
                        <Setter Property="Padding" Value="10,6"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#3D424B"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#53FC18"/>
                                            <Setter Property="Foreground" Value="Black"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" 
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                                            <Path Fill="{TemplateBinding Foreground}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" Data="M 0 0 L 4 4 L 8 0 Z"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" Margin="10,0,30,0" VerticalAlignment="Center" HorizontalAlignment="Left" TextBlock.Foreground="{TemplateBinding Foreground}" />
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Border x:Name="DropDownBorder" Background="#25272B" BorderThickness="1" BorderBrush="#3D424B" CornerRadius="4" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TabButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="#25272B"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3D424B"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#53FC18"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#25272B" BorderThickness="1" CornerRadius="10" Background="#1A1C20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Grid Grid.Row="0" Background="#25272B" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="15,0,0,0" VerticalAlignment="Center">
                    <Image Source="pack://application:,,,/icon.ico" Width="18" Height="18" Margin="0,0,8,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="KickDownloader Pro" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

                <Button Grid.Column="2" Width="45" Height="30" Margin="0,5,5,5" Background="Transparent" Foreground="White" Content="🗕" Click="MinimizeButton_Click" ToolTip="Küçült">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border CornerRadius="4" Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#333333"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Grid.Column="3" Width="45" Height="30" Margin="0,5,10,5" Background="Transparent" Foreground="White" Content="✕" Click="CloseButton_Click" ToolTip="Kapat">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border CornerRadius="4" Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E74C3C"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

                <!-- Main Content -->
            <Grid Grid.Row="1" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Tabs -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                    <RadioButton x:Name="TabDownloader" Content="İndirici" IsChecked="True" Checked="TabDownloader_Checked" Style="{StaticResource TabButtonStyle}" />
                    <RadioButton x:Name="TabHistory" Content="İndirme Geçmişi" Margin="10,0,0,0" Checked="TabHistory_Checked" Style="{StaticResource TabButtonStyle}"/>
                    <RadioButton x:Name="TabGuide" Content="Kılavuz" Margin="10,0,0,0" Checked="TabGuide_Checked" Style="{StaticResource TabButtonStyle}"/>
                </StackPanel>

                <!-- Downloader View -->
                <Grid x:Name="DownloaderView" Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                <!-- Preview Section -->
                <Border Grid.Row="0" Margin="0,0,0,15" Background="#25272B" CornerRadius="8" Padding="15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border CornerRadius="6" Width="120" Height="68" Background="#3D424B">
                            <Grid>
                                <Border x:Name="ImageClipBorder" CornerRadius="6" Background="#141414" />
                                <Image x:Name="PreviewImage" Stretch="UniformToFill">
                                    <Image.Clip>
                                        <RectangleGeometry Rect="0,0,120,68" RadiusX="6" RadiusY="6" />
                                    </Image.Clip>
                                </Image>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Column="1" Margin="15,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="PreviewTitle" Text="Video Önizlemesi" FontWeight="Bold" FontSize="16" TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:Name="PreviewChannel" Text="Bilinmiyor" Foreground="#A0A0A0" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Link Input -->
                <StackPanel Grid.Row="1" Margin="0,0,0,15">
                    <TextBlock Text="Kick VOD / Clip Linki:" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#A0A0A0"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Watermark/Placeholder TextBox setup -->
                        <Grid Grid.Column="0">
                            <TextBox x:Name="UrlTextBox" TextChanged="UrlTextBox_TextChanged"/>
                            <TextBlock x:Name="UrlPlaceholder" IsHitTestVisible="False" Text="https://kick.com/..." 
                                       VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0" 
                                       Foreground="#505050" FontStyle="Italic"/>
                        </Grid>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10,0,0,0">
                            <Button Content="Yapıştır" Width="70" Click="PasteButton_Click" Background="#3D424B" Foreground="White" Margin="0,0,5,0"/>
                            <Button Content="Önizle" Width="80" Click="PreviewButton_Click" Background="#2D323B" Foreground="White"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- Save Path Selection -->
                <StackPanel Grid.Row="2" Margin="0,0,0,15">
                    <TextBlock Text="Kayıt Klasörü:" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#A0A0A0"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="FolderTextBox" Text="C:\KickDownloads"/>
                        <Button Grid.Column="1" Margin="10,0,0,0" Content="..." Width="40" Click="BrowseFolder_Click" Background="#2D323B" Foreground="White"/>
                    </Grid>
                </StackPanel>

                <!-- Filename & Trimming & Quality -->
                <Grid Grid.Row="3" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Dosya Adı:" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#A0A0A0"/>
                        <TextBox x:Name="FileNameTextBox" Text="kick_video" Height="32"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,10,0">
                        <TextBlock Text="Kalite:" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#B0B0B0"/>
                        <ComboBox x:Name="QualityComboBox" SelectedIndex="0" Height="32">
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,0,10,0">
                        <TextBlock Text="Başlangıç" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#B0B0B0"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="StartTimeTextBox" Text="00:00:00" ToolTip="Örnek: 00:15:30" Height="32" PreviewTextInput="TimeTextBox_PreviewTextInput" PreviewKeyDown="TimeTextBox_PreviewKeyDown" ContextMenu="{x:Null}"/>
                            <StackPanel Grid.Column="1" Margin="2,0,0,0">
                                <Button Content="▲" Height="15" Width="20" FontSize="8" Padding="0" Click="StartTimeUp_Click" Background="#3D424B" Foreground="White" BorderThickness="0"/>
                                <Button Content="▼" Height="15" Width="20" FontSize="8" Padding="0" Margin="0,2,0,0" Click="StartTimeDown_Click" Background="#3D424B" Foreground="White" BorderThickness="0"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Column="3">
                        <TextBlock Text="Bitiş" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#B0B0B0"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="EndTimeTextBox" Text="00:00:00" ToolTip="Örnek: 01:25:00" Height="32" PreviewTextInput="TimeTextBox_PreviewTextInput" PreviewKeyDown="TimeTextBox_PreviewKeyDown" ContextMenu="{x:Null}"/>
                            <StackPanel Grid.Column="1" Margin="2,0,0,0">
                                <Button Content="▲" Height="15" Width="20" FontSize="8" Padding="0" Click="EndTimeUp_Click" Background="#3D424B" Foreground="White" BorderThickness="0"/>
                                <Button Content="▼" Height="15" Width="20" FontSize="8" Padding="0" Margin="0,2,0,0" Click="EndTimeDown_Click" Background="#3D424B" Foreground="White" BorderThickness="0"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Grid>

                <!-- Status Details -->
                <Grid Grid.Row="4" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="StatusTextBlock" Text="Bekleniyor..." Foreground="#A0A0A0" TextWrapping="Wrap"/>
                    <TextBlock x:Name="SpeedTextBlock" Grid.Column="1" Text="⏳ Hız: -" Foreground="#A0A0A0" HorizontalAlignment="Right" Margin="0,0,15,0"/>
                    <TextBlock x:Name="EtaTextBlock" Grid.Column="2" Text="⏰ Kalan: -" Foreground="#A0A0A0" HorizontalAlignment="Right"/>
                </Grid>

                <!-- Progress Value text -->
                <TextBlock x:Name="ProgressValueTextBlock" Grid.Row="5" Grid.RowSpan="2" Text="" FontSize="36" Foreground="#53FC18" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Margin="0,10,0,10"/>

                <!-- Action Buttons -->
                <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                    <Button x:Name="CancelButton" Content="İPTAL" Width="120" Height="40" Margin="0,0,15,0" IsEnabled="False" Click="CancelButton_Click" Background="#E74C3C" Foreground="White"/>
                    <Button x:Name="DownloadButton" Content="İNDİR" Width="200" Height="40" Click="DownloadButton_Click" FontSize="16"/>
                </StackPanel>
                </Grid>

                <!-- History View -->
                <Grid x:Name="HistoryView" Grid.Row="1" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" BorderBrush="#3D424B" BorderThickness="1" CornerRadius="8" Background="#141414" Padding="10">
                        <Grid>
                            <TextBlock x:Name="EmptyHistoryText" Text="Henüz indirilen bir kayıt yok." Foreground="#505050" FontWeight="SemiBold" FontStyle="Italic" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                            <ListBox x:Name="HistoryListBox" Background="Transparent" Foreground="White" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#25272B" CornerRadius="6" Margin="0,0,0,10" Padding="15" BorderBrush="#3D424B" BorderThickness="1" Width="525">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14" Foreground="White" TextTrimming="CharacterEllipsis" ToolTip="{Binding Title}"/>
                                                <TextBlock Grid.Row="1" Text="{Binding Url}" Foreground="#A0A0A0" FontSize="11" Margin="0,5,0,0" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Grid.Row="2" Text="{Binding Date}" Foreground="#53FC18" FontSize="11" Margin="0,10,0,0" HorizontalAlignment="Right" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <Button Grid.Row="1" Content="Geçmişi Temizle" Width="150" Height="35" Background="#E74C3C" Foreground="White" Margin="0,15,0,0" Click="ClearHistoryButton_Click"/>
                </Grid>

                <!-- Guide View -->
                <Grid x:Name="GuideView" Grid.Row="1" Visibility="Collapsed">
                    <Border BorderBrush="#3D424B" BorderThickness="1" CornerRadius="8" Background="#141414" Padding="20">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="📖 Kullanım Kılavuzu" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,15"/>

                                <TextBlock Text="1. Link Kopyalama" FontWeight="Bold" Foreground="#53FC18" Margin="0,10,0,5"/>
                                <TextBlock Text="Kick.com üzerinden indirmek istediğiniz VOD veya Klip linkini kopyalayın." Foreground="#E0E0E0" TextWrapping="Wrap"/>

                                <TextBlock Text="2. Yapıştır ve Önizle" FontWeight="Bold" Foreground="#53FC18" Margin="0,10,0,5"/>
                                <TextBlock Text="Linki programdaki link kutusuna yapıştırın ve 'Önizle' butonuna tıklayarak video bilgilerini getirin." Foreground="#E0E0E0" TextWrapping="Wrap"/>

                                <TextBlock Text="3. Kayıt Ayarları" FontWeight="Bold" Foreground="#53FC18" Margin="0,10,0,5"/>
                                <TextBlock Text="Videonun kaydedileceği klasörü ve dosya adını belirleyin." Foreground="#E0E0E0" TextWrapping="Wrap"/>

                                <TextBlock Text="4. Zaman ve Kalite (Opsiyonel)" FontWeight="Bold" Foreground="#53FC18" Margin="0,10,0,5"/>
                                <TextBlock Text="• İndirmeden önce belirli bir başlangıç ve bitiş süresi seçebilirsiniz.&#x0a;• İndirme kalitesini ayarlayabilirsiniz." Foreground="#E0E0E0" TextWrapping="Wrap"/>

                                <TextBlock Text="5. İndir" FontWeight="Bold" Foreground="#53FC18" Margin="0,10,0,5"/>
                                <TextBlock Text="'İNDİR' butonuna basarak işlemi başlatın. İndirme yüzdesini anlık olarak takip edebilirsiniz." Foreground="#E0E0E0" TextWrapping="Wrap"/>

                                <TextBlock Text="6. Geçmiş" FontWeight="Bold" Foreground="#53FC18" Margin="0,10,0,5"/>
                                <TextBlock Text="İndirdiğiniz içeriklere 'İndirme Geçmişi' sekmesinden ulaşabilirsiniz." Foreground="#E0E0E0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <StackPanel Grid.Row="2">
                <!-- Social Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <Button Width="110" Height="35" Margin="0,0,10,0" Background="#5865F2" Click="DiscordButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="pack://application:,,,/discord.png" Width="24" Height="24" Margin="0,0,5,0" Stretch="Uniform" VerticalAlignment="Center"/>
                            <TextBlock Text="Discord" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Width="110" Height="35" Background="#53FC18" Click="KickButton_Click" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="pack://application:,,,/kick.png" Width="20" Height="20" Margin="0,0,5,0" Stretch="Uniform" VerticalAlignment="Center"/>
                            <TextBlock Text="Kick" FontWeight="Bold" Foreground="Black" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Width="110" Height="35" Background="#24292E" Click="GithubButton_Click" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="pack://application:,,,/github.png" Width="18" Height="18" Margin="0,0,5,0" Stretch="Uniform" VerticalAlignment="Center"/>
                            <TextBlock Text="GitHub" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Width="130" Height="35" Background="#F1C40F" Click="UpdateToolsButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔄" FontSize="16" Margin="0,0,5,0" Foreground="Black" VerticalAlignment="Center"/>
                            <TextBlock Text="Araçları Güncelle" FontWeight="Bold" Foreground="Black" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Footer -->
                <TextBlock Text="© ® Vibe Coding" Foreground="#505050" HorizontalAlignment="Center" FontSize="11" Margin="0,15,0,0" FontWeight="SemiBold"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
